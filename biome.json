{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"files": {
		"includes": [
			"**",
			"!dist",
			"!node_modules",
			"!.agents",
			"!.claude",
			"!.tmp"
		]
	},
	"overrides": [
		{
			"includes": ["**/*.test.ts", "**/__tests__/**/*.ts"],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					},
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	]
}
