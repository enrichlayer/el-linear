# el-linear — A pragmatic CLI for Linear.app
# Token can also be stored in ~/.config/el-linear/token or ~/.linear_api_token

# Linear personal API token (https://linear.app/settings/account/security)
# LINEAR_API_TOKEN=lin_api_...

# Token used by `el-linear profile migrate-legacy` when no --token-from flag
# is passed. Falls back to interactive prompt if neither is set.
# EL_LINEAR_TOKEN=lin_api_...

# Optional path to local/team OAuth app defaults for `el-linear init oauth`
# EL_LINEAR_OAUTH_CONFIG=~/.config/el-linear/team-oauth.json

# Set to any value to enable debug logging (stderr)
# EL_LINEAR_DEBUG=1

# Silence the legacy-config drift hint that fires when an upgraded user
# still has ~/.config/el-linear/{config.json,token} from before profiles.
# EL_LINEAR_SKIP_MIGRATION_HINT=1
